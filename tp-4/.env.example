# Copy to .env and adjust as needed. tp-4/api reads these directly from the
# environment (no .env loader) - export them in your shell, or use
# `docker compose --env-file` / a tool like direnv.

# Matches tp-4/docker-compose.yml's db service.
DATABASE_URL=postgres://mira:mira@localhost:5433/mira?sslmode=disable

# tp-4/api
PORT=8080
ENRICHMENT_WORKERS=4
ENRICHMENT_QUEUE_SIZE=128
ENRICHMENT_JOB_TIMEOUT=3s

# tp-4/cli
MIRA_API_URL=http://localhost:8080
