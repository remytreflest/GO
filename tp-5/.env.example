# Copy to .env and adjust as needed. cmd/mira-mcp reads this directly from
# the environment (no .env loader) - export it in your shell, or use a tool
# like direnv.

# URL of the tp-4/api HTTP server this MCP server talks to. Never point this
# at a database directly: the API is what triggers async enrichment.
MIRA_API_URL=http://localhost:8080
